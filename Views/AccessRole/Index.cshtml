@using DotNetAdmin.Core.Data.Entities
@using DotNetAdmin.Modules.Access.Role.Dtos
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var result = (PaginationResult<Role>)ViewBag.Result;
    var filter = (RoleFilterDto)ViewBag.Filter;
}

<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-800">Role Management</h1>
    <a href="@Url.RouteUrl("admin.v1.access.role.create")" class="btn btn-primary-tw">
        <i class="fas fa-plus me-1"></i> Add Role
    </a>
</div>

<div class="tw-card p-0 overflow-hidden">
    <form method="get" action="@Url.RouteUrl("admin.v1.access.role.index")" class="p-4 border-b border-gray-100">
        <div class="d-flex gap-3 flex-wrap">
            <input type="text" name="Search" value="@filter.Search" placeholder="Search role name..."
                   class="form-control" style="max-width:280px">
            <select name="Status" class="form-control" style="max-width:140px">
                <option value="">All Status</option>
                <option value="Active" selected="@(filter.Status == "Active")">Active</option>
                <option value="Inactive" selected="@(filter.Status == "Inactive")">Inactive</option>
            </select>
            <button type="submit" class="btn btn-primary-tw"><i class="fas fa-search me-1"></i> Filter</button>
            <a href="@Url.RouteUrl("admin.v1.access.role.index")" class="btn btn-danger">Reset</a>
        </div>
    </form>

    <form id="bulk-form" method="post" action="@Url.RouteUrl("admin.v1.access.role.delete_selected")?_method=DELETE">
        @Html.AntiForgeryToken()
        <input type="hidden" name="ids" id="bulk-ids">

        <div class="p-3 border-b border-gray-100 d-flex gap-2">
            <button type="button" onclick="deleteSelected()" class="btn btn-danger btn-sm">
                <i class="fas fa-trash me-1"></i> Delete Selected
            </button>
        </div>

        <div class="overflow-x-auto">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th style="width:36px"><input type="checkbox" id="check-all" class="form-check-input"></th>
                        <th>Search / Filter Row</th>
                    </tr>
                    <tr>
                        <th></th>
                        <th>#</th>
                        <th>Name</th>
                        <th>Status</th>
                        <th>Description</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                @{int rowNum = result.From;}
                @foreach (var role in result.Data)
                {
                    <tr>
                        <td><input type="checkbox" class="row-check form-check-input" value="@role.Id"></td>
                        <td>@rowNum</td>
                        <td>@role.Name</td>
                        <td>
                            <span class="badge @(role.Status == "Active" ? "bg-green-100 text-green-800" : "bg-gray-100 text-gray-600")">
                                @role.Status
                            </span>
                        </td>
                        <td>@role.Desc</td>
                        <td>
                            <div class="d-flex gap-1">
                                <a href="@Url.RouteUrl("admin.v1.access.role.permission.index", new { id = role.Id })"
                                   class="btn btn-success btn-sm" title="Permissions">
                                    <i class="fas fa-key"></i>
                                </a>
                                <a href="@Url.RouteUrl("admin.v1.access.role.edit", new { id = role.Id })"
                                   class="btn btn-primary-tw btn-sm"><i class="fas fa-edit"></i></a>
                                <form method="post" action="@Url.RouteUrl("admin.v1.access.role.delete", new { id = role.Id })?_method=DELETE"
                                      onsubmit="return confirm('Delete this role?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-danger btn-sm"><i class="fas fa-trash"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    rowNum++;
                }
                @if (!result.Data.Any())
                {
                    <tr><td colspan="6" class="text-center text-gray-400 py-8">No roles found.</td></tr>
                }
                </tbody>
            </table>
        </div>
    </form>

    @if (result.TotalPages > 1)
    {
        <div class="p-4 d-flex align-items-center justify-content-between border-t border-gray-100">
            <span class="text-sm text-gray-500">Showing @result.From–@result.To of @result.TotalCount</span>
            <ul class="pagination">
                @if (result.HasPrev) {
                    <li class="page-item"><a class="page-link" href="@Url.RouteUrl("admin.v1.access.role.index", new { filter.Search, filter.Status, Page = result.Page - 1 })">&laquo;</a></li>
                }
                @{ int pS = Math.Max(1, result.Page - 2); int pE = Math.Min(result.TotalPages, result.Page + 2); }
                @if (pS > 1) { <li class="page-item"><a class="page-link" href="@Url.RouteUrl("admin.v1.access.role.index", new { filter.Search, filter.Status, Page = 1 })">1</a></li> if (pS > 2) { <li class="page-item disabled"><span class="page-link">…</span></li> } }
                @for (int p = pS; p <= pE; p++) {
                    <li class="page-item @(p == result.Page ? "active" : "")"><a class="page-link" href="@Url.RouteUrl("admin.v1.access.role.index", new { filter.Search, filter.Status, Page = p })">@p</a></li>
                }
                @if (pE < result.TotalPages) { if (pE < result.TotalPages - 1) { <li class="page-item disabled"><span class="page-link">…</span></li> } <li class="page-item"><a class="page-link" href="@Url.RouteUrl("admin.v1.access.role.index", new { filter.Search, filter.Status, Page = result.TotalPages })">@result.TotalPages</a></li> }
                @if (result.HasNext) {
                    <li class="page-item"><a class="page-link" href="@Url.RouteUrl("admin.v1.access.role.index", new { filter.Search, filter.Status, Page = result.Page + 1 })">&raquo;</a></li>
                }
            </ul>
        </div>
    }
</div>

<script>
document.getElementById('check-all').addEventListener('change', function() {
    document.querySelectorAll('.row-check').forEach(c => c.checked = this.checked);
});
function deleteSelected() {
    const ids = [...document.querySelectorAll('.row-check:checked')].map(c => c.value);
    if (!ids.length) { alert('Select at least one role.'); return; }
    if (!confirm('Delete ' + ids.length + ' role(s)?')) return;
    document.getElementById('bulk-ids').value = ids.join(',');
    document.getElementById('bulk-form').submit();
}
</script>
