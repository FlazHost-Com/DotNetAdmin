@{
    Layout = "_AdminLayout";
    ViewBag.Title = "UI Components";
}

<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-800">UI Components</h1>
</div>

@* ── Section 1: Stat Card + Counter ── *@
<div class="tw-card p-6 mb-6">
    <h2 class="text-lg font-bold mb-4" style="color:var(--primary)">1. Stat Card + Counter</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="tw-card p-5 flex items-center gap-4" style="border-left:4px solid var(--primary)">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center text-white text-xl shrink-0" style="background:var(--primary)">
                <i class="fas fa-users"></i>
            </div>
            <div>
                <p class="text-xs text-gray-500 font-medium uppercase tracking-wide">Users</p>
                <p class="text-3xl font-bold counter" data-target="1250" style="color:var(--theme-dark)">0</p>
            </div>
        </div>
        <div class="tw-card p-5 flex items-center gap-4" style="border-left:4px solid #10B981">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center text-white text-xl shrink-0 bg-green-500">
                <i class="fas fa-shopping-cart"></i>
            </div>
            <div>
                <p class="text-xs text-gray-500 font-medium uppercase tracking-wide">Orders</p>
                <p class="text-3xl font-bold counter text-green-700" data-target="842">0</p>
            </div>
        </div>
        <div class="tw-card p-5 flex items-center gap-4" style="border-left:4px solid #8B5CF6">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center text-white text-xl shrink-0 bg-purple-500">
                <i class="fas fa-dollar-sign"></i>
            </div>
            <div>
                <p class="text-xs text-gray-500 font-medium uppercase tracking-wide">Revenue</p>
                <p class="text-3xl font-bold counter text-purple-700" data-target="98000">0</p>
            </div>
        </div>
        <div class="tw-card p-5 flex items-center gap-4" style="border-left:4px solid #F59E0B">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center text-white text-xl shrink-0 bg-yellow-400">
                <i class="fas fa-star"></i>
            </div>
            <div>
                <p class="text-xs text-gray-500 font-medium uppercase tracking-wide">Reviews</p>
                <p class="text-3xl font-bold counter text-yellow-700" data-target="4238">0</p>
            </div>
        </div>
    </div>
</div>

@* ── Section 2: Charts ── *@
<div class="tw-card p-6 mb-6">
    <h2 class="text-lg font-bold mb-4" style="color:var(--primary)">2. Chart</h2>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div>
            <h3 class="text-sm font-semibold text-gray-600 mb-3">Line Chart (Monthly Revenue)</h3>
            <div class="h-56"><canvas id="lineChart"></canvas></div>
        </div>
        <div>
            <h3 class="text-sm font-semibold text-gray-600 mb-3">Doughnut Chart (Category)</h3>
            <div class="h-56"><canvas id="doughnutChart"></canvas></div>
        </div>
    </div>
</div>

@* ── Section 3: Badge & Status ── *@
<div class="tw-card p-6 mb-6">
    <h2 class="text-lg font-bold mb-4" style="color:var(--primary)">3. Badge &amp; Status</h2>
    <div class="flex flex-wrap gap-3">
        <span class="badge text-bg-primary px-3 py-1 text-sm rounded-full font-medium text-white" style="background:var(--primary)">Primary</span>
        <span class="badge px-3 py-1 text-sm rounded-full font-medium bg-green-600 text-white">Active</span>
        <span class="badge px-3 py-1 text-sm rounded-full font-medium bg-red-500 text-white">Inactive</span>
        <span class="badge px-3 py-1 text-sm rounded-full font-medium bg-yellow-500 text-white">Pending</span>
        <span class="badge px-3 py-1 text-sm rounded-full font-medium bg-gray-500 text-white">Default</span>
        <span class="badge px-3 py-1 text-sm rounded-full font-medium bg-blue-500 text-white">Info</span>
        <span class="badge px-3 py-1 text-sm rounded-full font-medium bg-purple-500 text-white">Web</span>
        <span class="badge px-3 py-1 text-sm rounded-full font-medium bg-orange-500 text-white">API</span>
    </div>
</div>

@* ── Section 4: Alert ── *@
<div class="tw-card p-6 mb-6">
    <h2 class="text-lg font-bold mb-4" style="color:var(--primary)">4. Alert</h2>
    <div class="space-y-3">
        <div class="flex items-start gap-3 p-4 rounded-lg border" style="background:var(--theme-light);border-color:var(--primary)">
            <i class="fas fa-info-circle mt-0.5" style="color:var(--primary)"></i>
            <p class="text-sm" style="color:var(--theme-dark)"><strong>Primary:</strong> This is a themed primary alert message.</p>
        </div>
        <div class="flex items-start gap-3 p-4 rounded-lg border bg-green-50 border-green-400">
            <i class="fas fa-check-circle text-green-600 mt-0.5"></i>
            <p class="text-sm text-green-800"><strong>Success:</strong> Operation completed successfully.</p>
        </div>
        <div class="flex items-start gap-3 p-4 rounded-lg border bg-yellow-50 border-yellow-400">
            <i class="fas fa-exclamation-triangle text-yellow-600 mt-0.5"></i>
            <p class="text-sm text-yellow-800"><strong>Warning:</strong> Please check before proceeding.</p>
        </div>
        <div class="flex items-start gap-3 p-4 rounded-lg border bg-red-50 border-red-400">
            <i class="fas fa-times-circle text-red-600 mt-0.5"></i>
            <p class="text-sm text-red-800"><strong>Error:</strong> Something went wrong. Please try again.</p>
        </div>
    </div>
</div>

@* ── Section 5: Button & Dropdown ── *@
<div class="tw-card p-6 mb-6">
    <h2 class="text-lg font-bold mb-4" style="color:var(--primary)">5. Button &amp; Dropdown Action</h2>
    <div class="flex flex-wrap gap-3 mb-4">
        <button class="btn btn-primary-tw">Primary</button>
        <button class="btn btn-success">Success</button>
        <button class="btn btn-danger">Danger</button>
        <button class="btn bg-yellow-500 text-white hover:bg-yellow-600">Warning</button>
        <button class="btn bg-gray-500 text-white hover:bg-gray-600">Default</button>
        <button class="btn btn-primary-tw btn-sm">Small</button>
        <button class="btn btn-success" disabled>Disabled</button>
    </div>
    <div class="flex flex-wrap gap-3">
        <div class="dropdown">
            <button class="btn btn-primary-tw dropdown-toggle" data-toggle-dd>
                Action
            </button>
            <div class="dropdown-menu">
                <a href="#" class="dropdown-item"><i class="fas fa-eye"></i> View</a>
                <a href="#" class="dropdown-item"><i class="fas fa-edit"></i> Edit</a>
                <div class="dropdown-divider"></div>
                <a href="#" class="dropdown-item danger"><i class="fas fa-trash"></i> Delete</a>
            </div>
        </div>
    </div>
</div>

@* ── Section 6: Modal / Toast / Confirm ── *@
<div class="tw-card p-6 mb-6">
    <h2 class="text-lg font-bold mb-4" style="color:var(--primary)">6. Modal / Toast / Confirm</h2>
    <div class="flex flex-wrap gap-3">
        <button class="btn btn-primary-tw" onclick="Toast('This is a success toast!', 'success')">Toast Success</button>
        <button class="btn btn-danger" onclick="Toast('This is an error toast!', 'error')">Toast Error</button>
        <button class="btn bg-yellow-500 text-white hover:bg-yellow-600" onclick="openModal('demo-modal')">Open Modal</button>
        <button class="btn bg-gray-600 text-white hover:bg-gray-700" onclick="openConfirm('Are you sure you want to delete this item?', function(){ Toast('Deleted!', 'success'); })">Confirm Dialog</button>
    </div>

    @* Demo Modal *@
    <div id="demo-modal" class="modal-overlay">
        <div class="modal-box">
            <div class="modal-header">
                <span>Demo Modal</span>
                <button onclick="closeModal('demo-modal')" class="modal-close"><i class="fas fa-times"></i></button>
            </div>
            <div class="modal-body">
                <p>This is a demo modal dialog. You can put any content here.</p>
            </div>
            <div class="modal-footer">
                <button onclick="closeModal('demo-modal')" class="btn bg-gray-200 text-gray-700">Cancel</button>
                <button onclick="closeModal('demo-modal'); Toast('Action confirmed!', 'success')" class="btn btn-primary-tw">Confirm</button>
            </div>
        </div>
    </div>
</div>

@* ── Section 7: Form ── *@
<div class="tw-card p-6 mb-6">
    <h2 class="text-lg font-bold mb-4" style="color:var(--primary)">7. Form</h2>
    <form class="space-y-4" onsubmit="return false">
        <div>
            <label class="form-label fw-semibold">Text Input</label>
            <input type="text" class="form-control" placeholder="Enter text…">
        </div>
        <div>
            <label class="form-label fw-semibold">Text Input (Invalid)</label>
            <input type="text" class="form-control is-invalid" value="invalid value">
            <div class="invalid-feedback">This field is required.</div>
        </div>
        <div>
            <label class="form-label fw-semibold">Select</label>
            <select class="form-control">
                <option>Option 1</option>
                <option>Option 2</option>
                <option>Option 3</option>
            </select>
        </div>
        <div>
            <label class="form-label fw-semibold">Textarea</label>
            <textarea class="form-control" rows="3" placeholder="Enter description…"></textarea>
        </div>
        <div>
            <label class="form-label fw-semibold">File Input (with preview)</label>
            <div class="mb-2" id="file-preview-box">
                <img src="/media/access/user/user.png" style="max-width:120px" class="rounded border p-1">
            </div>
            <input type="file" class="form-control" accept="image/*" onchange="previewFormImage(event)">
        </div>
        <div>
            <label class="form-label fw-semibold">Checkbox</label>
            <div class="flex flex-wrap gap-4">
                <label class="flex items-center gap-2"><input type="checkbox" class="form-check-input" checked> <span class="text-sm text-gray-700">Option A</span></label>
                <label class="flex items-center gap-2"><input type="checkbox" class="form-check-input"> <span class="text-sm text-gray-700">Option B</span></label>
                <label class="flex items-center gap-2"><input type="checkbox" class="form-check-input"> <span class="text-sm text-gray-700">Option C</span></label>
            </div>
        </div>
        <div class="flex gap-2">
            <button type="submit" class="btn btn-primary-tw">Submit</button>
            <button type="reset" class="btn bg-gray-200 text-gray-700 hover:bg-gray-300">Reset</button>
        </div>
    </form>
</div>

@* ── Section 8: Rich Text Editor (Trumbowyg + File Manager) ── *@
<div class="tw-card p-6 mb-6">
    <h2 class="text-lg font-bold mb-4" style="color:var(--primary)">8. Rich Text Editor</h2>
    <label class="form-label fw-semibold">Trumbowyg Editor with File Manager</label>
    <textarea id="demo-editor" class="trumbowyg-editor form-control" name="content">
        <p>Hello, this is a <strong>rich text editor</strong> demo. You can insert images using the File Manager button.</p>
    </textarea>
</div>

@* ── Section 9: Data Table + Pagination ── *@
<div class="tw-card p-6 mb-6">
    <h2 class="text-lg font-bold mb-4" style="color:var(--primary)">9. Data Table + Pagination</h2>
    <div class="mb-3 flex items-center justify-between">
        <div class="flex gap-2">
            <input type="text" class="form-control text-sm" placeholder="Search…" style="width:200px">
            <button class="btn btn-primary-tw btn-sm">Search</button>
        </div>
        <div class="flex gap-2">
            <select class="form-control text-sm" style="width:80px">
                <option>10</option>
                <option>25</option>
                <option>50</option>
            </select>
        </div>
    </div>
    <div class="overflow-x-auto">
        <table class="table w-full text-sm">
            <thead>
                <tr class="bg-gray-50">
                    <th class="py-2 px-4 text-left border-b"><input type="checkbox" class="form-check-input" id="select-all-demo" onchange="document.querySelectorAll('.row-cb').forEach(function(c){c.checked=this.checked},this)"></th>
                    <th class="py-2 px-4 text-left border-b font-medium text-gray-600">Filter Row</th>
                    <th class="py-2 px-4 text-left border-b font-medium text-gray-600"></th>
                    <th class="py-2 px-4 text-left border-b font-medium text-gray-600"></th>
                    <th class="py-2 px-4 text-left border-b font-medium text-gray-600"></th>
                </tr>
                <tr class="bg-gray-50">
                    <th class="py-2 px-4 border-b font-medium text-gray-600">#</th>
                    <th class="py-2 px-4 text-left border-b font-medium text-gray-600">Name</th>
                    <th class="py-2 px-4 text-left border-b font-medium text-gray-600">Email</th>
                    <th class="py-2 px-4 text-left border-b font-medium text-gray-600">Status</th>
                    <th class="py-2 px-4 text-left border-b font-medium text-gray-600">Action</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 1; i <= 5; i++)
                {
                    <tr class="hover:bg-gray-50 border-b border-gray-100">
                        <td class="py-2 px-4"><input type="checkbox" class="form-check-input row-cb"></td>
                        <td class="py-2 px-4 font-medium">Sample User @i</td>
                        <td class="py-2 px-4 text-gray-500">user@(i)@@example.com</td>
                        <td class="py-2 px-4">
                            <span class="px-2 py-0.5 text-xs rounded-full @(i % 2 == 0 ? "bg-green-100 text-green-700" : "bg-red-100 text-red-700")">
                                @(i % 2 == 0 ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td class="py-2 px-4">
                            <div class="dropdown">
                                <button class="btn btn-primary-tw btn-sm dropdown-toggle" data-toggle-dd>Action</button>
                                <div id="dd-row-@i" class="dropdown-menu">
                                    <a href="#" class="dropdown-item"><i class="fas fa-edit"></i> Edit</a>
                                    <a href="#" class="dropdown-item danger"><i class="fas fa-trash"></i> Delete</a>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="mt-4 flex items-center justify-between text-sm text-gray-500">
        <span>Showing 1–5 of 25</span>
        <nav><ul class="pagination flex gap-1">
            <li class="page-item disabled"><a class="page-link px-3 py-1 rounded border text-gray-400">Previous</a></li>
            <li class="page-item active"><a class="page-link px-3 py-1 rounded border text-white" style="background:var(--primary)">1</a></li>
            <li class="page-item"><a class="page-link px-3 py-1 rounded border text-gray-700 hover:bg-gray-100" href="#">2</a></li>
            <li class="page-item"><a class="page-link px-3 py-1 rounded border text-gray-700 hover:bg-gray-100" href="#">3</a></li>
            <li class="page-item disabled"><span class="page-link px-3 py-1 rounded border text-gray-400">…</span></li>
            <li class="page-item"><a class="page-link px-3 py-1 rounded border text-gray-700 hover:bg-gray-100" href="#">5</a></li>
            <li class="page-item"><a class="page-link px-3 py-1 rounded border text-gray-700 hover:bg-gray-100" href="#">Next</a></li>
        </ul></nav>
    </div>
</div>

@section Scripts {
<script>
// Counter animation
document.querySelectorAll('.counter').forEach(function(el) {
    var target = parseInt(el.getAttribute('data-target')) || 0;
    var start = 0;
    var step = Math.ceil(target / 80);
    var timer = setInterval(function() {
        start = Math.min(start + step, target);
        el.textContent = start.toLocaleString();
        if (start >= target) clearInterval(timer);
    }, 16);
});

// Charts
var primary = getComputedStyle(document.documentElement).getPropertyValue('--primary').trim() || '#3B82F6';
var secondary = getComputedStyle(document.documentElement).getPropertyValue('--secondary').trim() || '#60A5FA';

new Chart(document.getElementById('lineChart'), {
    type: 'line',
    data: {
        labels: ['Jan','Feb','Mar','Apr','May','Jun'],
        datasets: [{
            label: 'Revenue',
            data: [12000, 19000, 15000, 22000, 18000, 28000],
            borderColor: primary,
            backgroundColor: primary + '20',
            tension: 0.4,
            fill: true
        }]
    },
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
});

new Chart(document.getElementById('doughnutChart'), {
    type: 'doughnut',
    data: {
        labels: ['Electronics','Fashion','Food','Sports'],
        datasets: [{
            data: [35, 25, 20, 20],
            backgroundColor: [primary, secondary, '#10B981', '#F59E0B']
        }]
    },
    options: { responsive: true, maintainAspectRatio: false }
});

function openModal(id) { document.getElementById(id).classList.add('show'); }
function closeModal(id) { document.getElementById(id).classList.remove('show'); }
function openConfirm(msg, cb) {
    if (confirm(msg)) cb();
}

function previewFormImage(event) {
    var box = document.getElementById('file-preview-box');
    box.innerHTML = '';
    var file = event.target.files[0];
    if (file) {
        var reader = new FileReader();
        reader.onload = function(e) {
            var img = document.createElement('img');
            img.src = e.target.result;
            img.style.maxWidth = '120px';
            img.className = 'rounded border p-1';
            box.appendChild(img);
        };
        reader.readAsDataURL(file);
    }
}
</script>
}
